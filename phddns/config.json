{
  "version": "1.0.6",
  "name": "phddns-花生壳",
  "url": "https://www.oray.com",
  "slug": "phddns",
  "description": "A Home Assistant add-on for Oray's phddns service.这是一个花生壳客户端",
  "arch": ["amd64", "i386"],
  "startup": "services",
  "hassio_role": "manager",
  "boot": "manual",
  "privileged": [ 
    "NET_ADMIN",
    "SYS_ADMIN"
  ],
  "devices": [
    "/dev/net/tun"
  ],
  "options": {},
  "schema": {},
  "map": [
    "config:rw"
  ],
  "restart": "always",
  "host_network": true,
  "environment": {
    "TZ": "Asia/Shanghai"
  }
}
